# Endpoint do Ollama (servidor de modelos locais)
OLLAMA_BASE_URL=http://localhost:11434

# Modelo de linguagem local (geração e raciocínio dos agentes)
LLM_MODEL=llama3.1:8b

# Modelo de embeddings local (indexação e busca semântica)
EMBED_MODEL=nomic-embed-text

# Parâmetros de RAG
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Máximo de reprocessamentos solicitados pelo Agente Verificador
MAX_ITER=2
